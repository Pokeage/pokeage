{
  "name": "@pokeage/sdk",
  "version": "0.4.1",
  "description": "TypeScript client for the pokeAge $PAGE on-chain economy: PDAs, account decoding, Token-2022 balances, and instruction builders.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "jest",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "solana",
    "anchor",
    "token-2022",
    "web3",
    "pokeage",
    "sdk"
  ],
  "author": {
    "name": "pokeAge core"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pokeage/pokeage.git",
    "directory": "sdk"
  },
  "bugs": {
    "url": "https://github.com/Pokeage/pokeage/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@pokeage/engine": "*",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0"
  }
}
