# copy to .env and fill in. never commit a real .env.

# rpc endpoint the cli and examples talk to
POKEAGE_RPC_URL=https://api.devnet.solana.com

# cluster: devnet | mainnet-beta | localnet
POKEAGE_NETWORK=devnet

# path to the signer used by the cli
POKEAGE_KEYPAIR_PATH=~/.config/solana/id.json

# $PAGE mint (set after launch; Token-2022)
POKEAGE_MINT=

# log verbosity: error | warn | info | debug
POKEAGE_LOG_LEVEL=info
