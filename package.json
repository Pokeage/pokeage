{
  "name": "@pokeage/engine",
  "version": "0.4.1",
  "description": "Deterministic, dependency-free monster-RPG simulation engine: type chart, damage, leveling, evolution, encounters, battles, catching, and offline progression.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:sdk": "tsc -p sdk/tsconfig.json",
    "typecheck": "tsc --noEmit && tsc --noEmit -p sdk/tsconfig.json",
    "test": "jest",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"sdk/src/**/*.ts\" \"tests/**/*.ts\" \"examples/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"sdk/src/**/*.ts\"",
    "example": "ts-node examples/simulate-run.ts",
    "clean": "rm -rf dist sdk/dist"
  },
  "keywords": [
    "solana",
    "anchor",
    "game-engine",
    "monster-rpg",
    "typescript",
    "web3",
    "token-2022",
    "gamefi",
    "deterministic",
    "simulation"
  ],
  "author": {
    "name": "pokeAge core"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pokeage/pokeage.git"
  },
  "bugs": {
    "url": "https://github.com/Pokeage/pokeage/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.8",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
